# ============================================================
#  Hive 蜂巢 · 部署环境变量样例
#  使用：复制为 .env 后按需修改，docker compose 会自动读取
#      cp .env.example .env
#  .env 含密钥，已在 .gitignore 忽略，勿提交
# ============================================================

# ---- 对外端口 ----
# 浏览器访问 = http://宿主机IP:APP_PORT
APP_PORT=8080

# ---- 镜像版本 ----
# 拉取哪个 tag：latest / v1.0.0 / main 等
HIVE_IMAGE_TAG=latest

# ---- 数据库 ----
HIVE_DB_NAME=hive_db
HIVE_DB_USER=root
HIVE_DB_PASSWORD=123456

# ---- 安全 ----
# JWT 签名密钥：生产环境务必改成一段足够长的随机字符串
HIVE_JWT_SECRET=hive-2026-course-project-secret-key-7f3a9c1e
HIVE_JWT_EXPIRE_DAYS=7

# ---- 时区 ----
TZ=Asia/Shanghai

# ============================================================
#  进阶项（一般无需修改，application.yml 内已有默认值）：
#  HIVE_MAX_FILE_SIZE=10MB        单文件上传上限
#  HIVE_MAX_REQUEST_SIZE=12MB     单请求总大小上限
#  HIVE_SQL_INIT_MODE=always      建表/种子脚本执行模式（幂等，可保持 always）
#  HIVE_LOG_LEVEL=info            应用日志级别
# ============================================================
