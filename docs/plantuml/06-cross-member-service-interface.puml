package "江民智 jiangminzhi" as JMZ {
  interface AuthService <<ServiceInterface>>
  class AuthServiceImpl <<ServiceImpl>>
  interface UserService <<ServiceInterface>>
  class UserServiceImpl <<ServiceImpl>>
