@startuml
' 这张图是新增版本：跨组接口调用关系，原 06-cross-member-relationships.puml 不修改
!pragma layout smetana
left to right direction
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam classAttributeIconSize 0
hide empty members
skinparam shadowing false
skinparam class {
  BackgroundColor<<ServiceInterface>> #FFF7D6
  BackgroundColor<<ServiceImpl>> #E9F7EF
  BackgroundColor<<Mapper>> #F5E8FF
  BackgroundColor<<Infra>> #F2F2F2
  BorderColor #555555
}

title 跨组调用关系汇总（只画跨包依赖，避免线条和组内关系混在一起）

legend left
  每个组内的 Controller/DTO/实体关系见第 2-5 张
  本图只保留跨组 Service、Mapper、推送、事件依赖
  虚线空心三角表示 Impl 实现接口；实线表示跨组调用或构造注入
endlegend

package "张致硕 zhangzhishuo" as ZZS {
  interface HiveService <<ServiceInterface>>
  class HiveServiceImpl <<ServiceImpl>>
  interface FileService <<ServiceInterface>>
  class FileServiceImpl <<ServiceImpl>>
  interface HiveMapper <<Mapper>>
  interface HiveMemberMapper <<Mapper>>
  interface InviteMapper <<Mapper>>
  interface FileMapper <<Mapper>>
}

